# =============================================================================
# Logos Monorepo — 環境配置模板
# 複製為 .env 並填入本機實際路徑，.env 不進版控
# =============================================================================

# --- 專案根目錄 ---
LOGOS_ROOT=/data/logos

# --- 家目錄與個人資料 ---
HOME_DIR=/home/<your-username>

# --- Secrets 目錄（在家目錄外於 monorepo，不進版控）---
SECRETS_DIR=$HOME_DIR/.logos/secrets

# --- Agent 設定目錄 ---
CLAUDE_CONFIG_DIR=$HOME_DIR/.claude
GEMINI_CONFIG_DIR=$HOME_DIR/.gemini        # 應為 symlink → education/global-disciplines

# --- Global Disciplines Sync 目標 ---
GLOBAL_DISCIPLINES_SRC=$LOGOS_ROOT/education/global-disciplines/.agent
DISCIPLINE_CONFIG=$LOGOS_ROOT/education/global-disciplines/discipline_config.json

# --- LINE 個人帳號（Chrome CDP）---
LINE_PERSONAL_CHROME_DATA=$HOME_DIR/.logos/chrome-data/line-personal
LINE_PERSONAL_CDP_URL=http://localhost:9222
LINE_PERSONAL_EXT_ID=ophjlpahpchlmihnnnihgmmeilfjmjjc

# --- LINE 官方帳號（Messaging API）---
LINE_OFFICIAL_CHANNEL_SECRET=$SECRETS_DIR/line-official/channel-secret
LINE_OFFICIAL_CHANNEL_TOKEN=$SECRETS_DIR/line-official/channel-access-token
LINE_OFFICIAL_WEBHOOK_PORT=8080
