# Digest 設定範本
# 複製此檔為 .env 並填入實際值
# .env 已 gitignore，不會進版控

# ── 資料庫 ────────────────────────────────────────────────────────
# Digest 自有的 PostgreSQL 連線字串
DB_URL=postgresql://line:line@localhost:5433/digest

# ── Channel 來源 ──────────────────────────────────────────────
# 各 channel REST API 端點（由各 channel 服務提供）
# 留空則跳過該 channel

LINE_PERSONAL_API=http://localhost:8000   # line-personal FastAPI
LINE_OFFICIAL_API=http://localhost:8001   # line-official FastAPI

# 若 channel 資料以資料夾方式暴露，可改填本地路徑
# LINE_PERSONAL_DATA=/data/personal/line-personal/data

# ── 掃描設定 ──────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=10          # 定期掃描間隔（分鐘）
LOOKBACK_MINUTES=60               # 每次掃描回溯多少分鐘內的新訊息

# ── 分類設定 ──────────────────────────────────────────────────
# 分類規則設定檔路徑（JSON/YAML），留空則使用內建預設
CLASSIFICATION_CONFIG=            # 例：/data/logos/liaison/digest/config/classification.yaml

# ── 呈報目標 ──────────────────────────────────────────────────
# 摘要要推送到哪個 channel
REPORT_CHANNEL=line-official      # line-personal | line-official | stdout

# 呈報對象（channel-specific ID）
REPORT_TARGET_ID=                 # LINE mid / chat_id / 等

# ── 呈報時機 ──────────────────────────────────────────────────
# cron 格式，留空則只有達到閾值時才主動呈報
REPORT_SCHEDULE=0 8,20 * * *      # 每天 08:00 / 20:00

# 立即呈報的優先級閾值（低於此值只列入下次定期摘要）
REPORT_IMMEDIATE_PRIORITY=critical  # critical | high | any
